{
  "name": "forza-telemetry-web",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/server",
    "apps/dashboard"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:server": "cargo run -p forza-telemetry-server",
    "dev:server:node": "npm run dev -w @forza-telemetry/server",
    "dev:dashboard": "npm run dev -w @forza-telemetry/dashboard",
    "build": "npm run build -w @forza-telemetry/dashboard && cargo build -p forza-telemetry-server --release",
    "build:dashboard": "npm run build -w @forza-telemetry/dashboard",
    "build:server": "cargo build -p forza-telemetry-server --release",
    "package:windows": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe -ExecutionPolicy Bypass -File scripts\\package-windows.ps1",
    "typecheck": "cargo check -p forza-telemetry-server && npm run typecheck -w @forza-telemetry/dashboard",
    "validate:env": "scripts\\validate-env.cmd",
    "standalone": "scripts\\standalone.cmd",
    "smoke:standalone": "scripts\\smoke-standalone.cmd",
    "start": "target\\release\\sim-telemetry-server.exe",
    "start:node": "npm run start -w @forza-telemetry/server"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
